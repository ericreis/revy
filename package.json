{
  "name": "revy",
  "version": "0.0.1",
  "private": true,
  "description": "An agentic PR review tool, built as a local AXI.",
  "type": "module",
  "bin": {
    "revy": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "revy": "node dist/cli.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/refractor": "^3.4.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-diff-view": "^3.3.0",
    "react-dom": "^18.3.1",
    "refractor": "^3.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
